{
  "expo": {
    "name": "HydroGateway",
    "slug": "hydro-gateway",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A2342"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A2342"
      },
      "package": "ci.hydroscope.hydrogateway",
      "targetSdkVersion": 33,
      "permissions": [
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0A2342",
          "sounds": []
        }
      ],
      [
        "expo-secure-store"
      ]
    ],
    "extra": {
      "webhookUrl": "https://admin.hydroscope.ci/api/webhook/sms",
      "eas": {
        "projectId": "4e5e5873-0dcc-49ce-bbc4-6d19ba11350f"
      }
    },
    "owner": "bakaramoko-traores-organization"
  }
}
